---
// src/components/Hero.astro
import heroBg from '../assets/hero_1.png';
---

<section class="relative w-full h-[70vh] flex items-center justify-center overflow-hidden">
  <img 
    src={heroBg.src} 
    alt="Diseño de interiores Swoody" 
    class="absolute inset-0 w-full h-full object-cover select-none pointer-events-none"
  />
  
  <div class="absolute inset-0 bg-black/40"></div>

  <div class="relative z-10 text-center max-w-3xl px-4 text-white">
    <h1 class="text-4xl md:text-6xl font-black mb-4 drop-shadow-md">
      Muebles a un click de distancia
    </h1>
    <p class="text-gray-200 text-lg md:text-xl mb-8 drop-shadow-sm">
      Explora las mejores mueblerías de Panamá.
    </p>

    <!-- BOTÓN ACTUALIZADO -->
    <a 
      href="#catalogo" 
      class="inline-flex items-center gap-2 bg-yellow-500 text-black px-8 py-3 rounded-full font-bold hover:bg-yellow-400 transition-colors group"
    >
      Ver Catálogo
      
      <!-- Icono de flecha (el mismo del Header, rotado 90 grados) -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="transform group-hover:translate-y-0.5 transition-transform"
      >
        <path d="m6 9 6 6 6-6"/>
      </svg>
    </a>
  </div>
</section>