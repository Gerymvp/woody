---
interface Props {
  id: string | number;
  nombre: string;
  precio: number;
  imagen: string;
  categoria: string;
}

const { id, nombre, precio, imagen, categoria } = Astro.props;
---

<div class="relative bg-gray-400 rounded-3xl aspect-[4/3] shadow-lg overflow-hidden group">

  <!-- Imagen del Producto -->
  <img
    src={imagen || "https://via.placeholder.com/600x400?text=Sin+Imagen"}
    alt={nombre}
    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
  />

  <!-- Contenedor inferior -->
  <div class="absolute bottom-4 left-4 right-4 flex gap-2">

    <!-- Botón Agregar al carrito -->
    <button
      type="button"
      class="add-to-cart relative bg-white/30 px-4 py-2 rounded-xl text-sm font-bold shadow-sm flex items-center overflow-hidden border border-white/20"
      data-product-id={String(id)}
      data-product-name={nombre}
      data-product-price={String(precio)}
      data-product-image={imagen}
      data-product-category={categoria}
    >
      <div class="absolute inset-0 backdrop-blur-md [mask-image:linear-gradient(to_right,black_0%,transparent_100%)]"></div>

      <span class="relative z-10 text-gray-900">
        Agregar a carrito
      </span>
    </button>

    <!-- Precio -->
    <div class="relative bg-white/30 px-4 py-2 rounded-xl text-sm font-bold shadow-sm flex items-center overflow-hidden border border-white/20">
      <div class="absolute inset-0 backdrop-blur-md [mask-image:linear-gradient(to_right,black_0%,transparent_100%)]"></div>
      <span class="relative z-10 text-gray-900">
        ${precio.toFixed(2)}
      </span>
    </div>

    <!-- Nombre -->
    <div class="relative flex-1 px-6 py-2 rounded-full font-bold text-gray-800 shadow-sm truncate border border-white/20 overflow-hidden">
      <div class="absolute inset-0 bg-white/40 backdrop-blur-lg [mask-image:linear-gradient(to_right,black_20%,transparent_100%)]"></div>
      <span class="relative z-10">
        {nombre}
      </span>
    </div>

  </div>

  <!-- Categoría -->
  <span class="absolute top-4 right-4 bg-black/40 backdrop-blur-sm text-white text-[10px] px-3 py-1 rounded-full uppercase tracking-wider">
    {categoria}
  </span>

</div>

<script>
  import { addToCart } from '../../lib/cart.js';

  document.querySelectorAll('.add-to-cart').forEach((button) => {
    if (!(button instanceof HTMLButtonElement)) return;
    if (button.dataset.bound === 'true') return;

    button.dataset.bound = 'true';

    button.addEventListener('click', () => {
      addToCart({
        id: button.dataset.productId,
        name: button.dataset.productName,
        price: button.dataset.productPrice,
        image: button.dataset.productImage,
        category: button.dataset.productCategory,
      });

      const original = button.textContent;

      button.textContent = '✓ Añadido';
      button.disabled = true;

      setTimeout(() => {
        button.textContent = original;
        button.disabled = false;
      }, 1200);
    });
  });
</script>