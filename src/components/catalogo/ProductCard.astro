---
interface Props {
  id: string | number;
  nombre: string;
  precio: number;
  imagen: string;
  categoria: string;
}

const { id, nombre, precio, imagen, categoria } = Astro.props;
---

<div class="group bg-white rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-1">

  <div class="relative h-64 overflow-hidden">
    <img
      src={imagen || "https://via.placeholder.com/600x400?text=Sin+Imagen"}
      alt={nombre}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
    />

    <span class="absolute top-3 right-3 bg-black/70 text-white text-xs px-3 py-1 rounded-full">
      {categoria}
    </span>
  </div>

  <div class="p-5">

    <h3 class="font-bold text-xl line-clamp-2 min-h-[56px]">
      {nombre}
    </h3>

    <div class="mt-3 flex items-center justify-between">

      <span class="text-2xl font-black text-yellow-600">
        ${precio.toFixed(2)}
      </span>

    </div>

    <button
      type="button"
      class="add-to-cart mt-5 w-full bg-yellow-500 hover:bg-yellow-400 text-black py-3 rounded-2xl font-bold transition-all duration-300 hover:scale-[1.02]"
      data-product-id={String(id)}
      data-product-name={nombre}
      data-product-price={String(precio)}
      data-product-image={imagen}
      data-product-category={categoria}
    >
      Añadir al carrito
    </button>

  </div>

</div>

<script>
  import { addToCart } from '../../lib/cart.js';

  document.querySelectorAll('.add-to-cart').forEach((button) => {
    if (!(button instanceof HTMLButtonElement)) return;
    if (button.dataset.bound === 'true') return;

    button.dataset.bound = 'true';

    button.addEventListener('click', () => {
      addToCart({
        id: button.dataset.productId,
        name: button.dataset.productName,
        price: button.dataset.productPrice,
        image: button.dataset.productImage,
        category: button.dataset.productCategory,
      });

      const original = button.textContent;

      button.textContent = '✓ Añadido';
      button.disabled = true;

      setTimeout(() => {
        button.textContent = original;
        button.disabled = false;
      }, 1200);
    });
  });
</script>