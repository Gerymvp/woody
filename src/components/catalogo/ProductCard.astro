---
// src/components/catalogo/ProductCard.astro
interface Props {
  titulo: string;
  precio: number;
  imagen: string;
  categoria: string;
}

const { titulo, precio, imagen, categoria } = Astro.props;
---

<div class="relative bg-gray-400 rounded-3xl aspect-[4/3] shadow-lg overflow-hidden group">
  <!-- Imagen del Producto -->
  <img 
    src={imagen} 
    alt={titulo} 
    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
  />

  <!-- Contenedor de Información con gradiente de desenfoque -->
  <div class="absolute bottom-4 left-4 right-4 flex gap-2">

    <!-- Agregar al carrito -->
    <div class="relative bg-white/30 px-4 py-2 rounded-xl text-sm font-bold shadow-sm flex items-center overflow-hidden border border-white/20">
      <div class="absolute inset-0 backdrop-blur-md [mask-image:linear-gradient(to_right,black_0%,transparent_100%)]"></div>
      <span class="relative z-10 text-gray-900">agregar a carrito</span>
    </div>
    
    <!-- Precio con desenfoque direccional -->
    <div class="relative bg-white/30 px-4 py-2 rounded-xl text-sm font-bold shadow-sm flex items-center overflow-hidden border border-white/20">
      <div class="absolute inset-0 backdrop-blur-md [mask-image:linear-gradient(to_right,black_0%,transparent_100%)]"></div>
      <span class="relative z-10 text-gray-900">${precio.toFixed(2)}</span>
    </div>

    <!-- Título con desenfoque de izquierda a derecha -->
    <div class="relative flex-1 px-6 py-2 rounded-full font-bold text-gray-800 shadow-sm truncate border border-white/20 overflow-hidden">
      <!-- Capa de desenfoque con máscara -->
      <div class="absolute inset-0 bg-white/40 backdrop-blur-lg [mask-image:linear-gradient(to_right,black_20%,transparent_100%)]"></div>
      <!-- Texto sobre el desenfoque -->
      <span class="relative z-10">{titulo}</span>
    </div>

  </div>
  
  <!-- Badge de Categoría -->
  <span class="absolute top-4 right-4 bg-black/40 backdrop-blur-sm text-white text-[10px] px-3 py-1 rounded-full uppercase tracking-wider">
    {categoria}
  </span>
</div>