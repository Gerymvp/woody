---
// src/components/admin/ProductManager.astro
// Este componente se encargará de renderizar la interfaz y manejar la lógica en el cliente.
---

<div class="space-y-8">
  <div class="flex justify-between items-center border-b pb-4">
    <div>
      <h2 class="text-2xl font-bold text-gray-800">Inventario de Productos</h2>
      <p class="text-sm text-gray-500">Crea, edita o elimina los productos del catálogo de Swoody.</p>
    </div>
    <button 
      id="open-create-modal"
      class="bg-gray-900 hover:bg-gray-800 text-white px-4 py-2 rounded-xl text-sm font-semibold transition shadow-sm"
    >
      + Nuevo Producto
    </button>
  </div>

  <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-100 text-gray-600 text-xs font-bold uppercase tracking-wider">
            <th class="p-4">Imagen</th>
            <th class="p-4">Producto</th>
            <th class="p-4">Categoría</th>
            <th class="p-4">Precio</th>
            <th class="p-4 text-right">Acciones</th>
          </tr>
        </thead>
        <tbody id="products-table-body" class="divide-y divide-gray-50 text-sm text-gray-700">
          <tr>
            <td colspan="5" class="p-8 text-center text-gray-400">Cargando productos...</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <div id="product-modal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center hidden">
    <div class="bg-white rounded-3xl w-full max-w-md p-6 shadow-xl border border-gray-100 animate-in fade-in zoom-in-95 duration-200">
      <div class="flex justify-between items-center mb-4">
        <h3 id="modal-title" class="text-lg font-bold text-gray-900">Agregar Producto</h3>
        <button id="close-modal" class="text-gray-400 hover:text-gray-600 text-2xl">&times;</button>
      </div>

      <form id="product-form" class="space-y-4">
        <input type="hidden" id="product-id" name="id" />
        
        <div>
          <label class="block text-xs font-bold text-gray-700 uppercase mb-1">Nombre del Producto</label>
          <input 
            type="text" 
            id="product-titulo" 
            name="titulo" 
            required 
            class="w-full px-4 py-2 rounded-xl border border-gray-200 focus:outline-none focus:border-gray-900 text-sm"
            placeholder="Ej. Cama Queen"
          />
        </div>

        <div>
          <label class="block text-xs font-bold text-gray-700 uppercase mb-1">Categoría</label>
          <select 
            id="product-categoria" 
            name="categoria" 
            required
            class="w-full px-4 py-2 rounded-xl border border-gray-200 focus:outline-none focus:border-gray-900 text-sm bg-white"
          >
            <option value="Sala">Sala</option>
            <option value="Comedor">Comedor</option>
            <option value="Dormitorio">Dormitorio</option>
            <option value="Empotrados">Empotrados</option>
            <option value="Oficina">Oficina</option>
          </select>
        </div>

        <div>
          <label class="block text-xs font-bold text-gray-700 uppercase mb-1">Precio ($)</label>
          <input 
            type="number" 
            step="0.01" 
            id="product-precio" 
            name="precio" 
            required 
            class="w-full px-4 py-2 rounded-xl border border-gray-200 focus:outline-none focus:border-gray-900 text-sm"
            placeholder="0.00"
          />
        </div>

        <div>
          <label class="block text-xs font-bold text-gray-700 uppercase mb-1">URL de la Imagen</label>
          <input 
            type="url" 
            id="product-imagen" 
            name="imagen_url" 
            required 
            class="w-full px-4 py-2 rounded-xl border border-gray-200 focus:outline-none focus:border-gray-900 text-sm"
            placeholder="https://ejemplo.com/imagen.jpg"
          />
        </div>

        <div class="flex gap-2 pt-4 border-t">
          <button 
            type="button" 
            id="cancel-modal"
            class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 px-4 py-2 rounded-xl text-sm font-semibold transition"
          >
            Cancelar
          </button>
          <button 
            type="submit" 
            class="flex-1 bg-gray-900 hover:bg-gray-800 text-white px-4 py-2 rounded-xl text-sm font-semibold transition shadow-sm"
          >
            Guardar
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  import { supabase } from '../../lib/supabase';

    interface Producto {
    id?: string | number;
    titulo: string;
    precio: number;
    imagen_url: string;
    categoria: string;
  }

  let localProducts: Producto[] = [];
  const tableBody = document.getElementById('products-table-body');
  const modal = document.getElementById('product-modal');
  const form = document.getElementById('product-form') as HTMLFormElement;
  const modalTitle = document.getElementById('modal-title');

  // Elementos de los inputs
  const inputId = document.getElementById('product-id') as HTMLInputElement;
  const inputTitulo = document.getElementById('product-titulo') as HTMLInputElement;
  const inputCategoria = document.getElementById('product-categoria') as HTMLInputElement;
  const inputPrecio = document.getElementById('product-precio') as HTMLInputElement;
  const inputImagen = document.getElementById('product-imagen') as HTMLInputElement;

  // Cargar productos inicialmente
  async function loadProducts() {
    const { data, error } = await supabase.from('productos').select('*').order('created_at', { ascending: false });
    if (error) {
      console.error('Error cargando productos:', error);
      return;
    }
    localProducts = data || [];
    renderProducts();
  }

  // Renderizar filas de la tabla
  function renderProducts() {
    if (!tableBody) return;
    if (localProducts.length === 0) {
      tableBody.innerHTML = `<tr><td colspan="5" class="p-8 text-center text-gray-400">No hay productos en el catálogo.</td></tr>`;
      return;
    }

    tableBody.innerHTML = localProducts.map(prod => `
      <tr class="hover:bg-gray-50/50 transition-colors" data-id="${prod.id}">
        <td class="p-4">
          <img src="${prod.imagen_url}" alt="${prod.titulo}" class="w-12 h-12 object-cover rounded-xl border border-gray-100" />
        </td>
        <td class="p-4 font-semibold text-gray-950">${prod.titulo}</td>
        <td class="p-4">
          <span class="bg-gray-100 text-gray-700 text-xs px-2.5 py-1 rounded-full uppercase tracking-wider font-medium">${prod.categoria}</span>
        </td>
        <td class="p-4 font-medium text-gray-900">$${Number(prod.precio).toFixed(2)}</td>
        <td class="p-4 text-right space-x-2">
          <button class="edit-btn text-blue-600 hover:text-blue-800 font-medium text-xs px-2 py-1 bg-blue-50 hover:bg-blue-100 rounded-lg transition" data-id="${prod.id}">Editar</button>
          <button class="delete-btn text-red-600 hover:text-red-800 font-medium text-xs px-2 py-1 bg-red-50 hover:bg-red-100 rounded-lg transition" data-id="${prod.id}">Eliminar</button>
        </td>
      </tr>
    `).join('');

    // Asignar listeners a los nuevos botones generados
    document.querySelectorAll('.edit-btn').forEach(btn => btn.addEventListener('click', handleEdit));
    document.querySelectorAll('.delete-btn').forEach(btn => btn.addEventListener('click', handleDelete));
  }

  // Modales
  function showModal(editMode = false) {
    modal?.classList.remove('hidden');
    modalTitle!.innerText = editMode ? 'Editar Producto' : 'Agregar Producto';
  }

  function hideModal() {
    modal?.classList.add('hidden');
    form.reset();
    inputId.value = '';
  }

  // Manejar el envío del Formulario (Crear y Editar)
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = inputId.value;
    const productPayload = {
      titulo: inputTitulo.value,
      categoria: inputCategoria.value,
      precio: parseFloat(inputPrecio.value),
      imagen_url: inputImagen.value
    };

    if (id) {
      // EDITAR: Convertimos el ID a número (Number) antes de pasarlo al .eq()
      // Si tu ID en Supabase es un UUID, déjalo simplemente como: .eq('id', id)
      const { error } = await supabase
        .from('productos')
        .update(productPayload)
        .eq('id', id);

      if (error) {
        alert('Error al actualizar: ' + error.message);
      } else {
        console.log('Producto actualizado correctamente');
      }
    } else {
      // Crear
      const { error } = await supabase.from('productos').insert([productPayload]);
      if (error) alert('Error al insertar: ' + error.message);
    }

    hideModal();
    await loadProducts(); // Aseguramos esperar a que recargue
  });

// Abrir formulario para editar
  function handleEdit(e: Event) {
    const id = (e.currentTarget as HTMLButtonElement).getAttribute('data-id');
    const product = localProducts.find(p => String(p.id) === String(id));
    if (!product) return;

    // Convertimos a String para que TypeScript no tire error en el .value
    inputId.value = product.id ? String(product.id) : '';
    inputTitulo.value = product.titulo;
    inputCategoria.value = product.categoria;
    inputPrecio.value = String(product.precio);
    inputImagen.value = product.imagen_url;

    showModal(true);
  }

// Eliminar Producto
  async function handleDelete(e: Event) {
    const id = (e.currentTarget as HTMLButtonElement).getAttribute('data-id');
    const product = localProducts.find(p => String(p.id) === String(id));
    if (!product || !confirm(`¿Estás seguro de que quieres eliminar "${product.titulo}"?`)) return;

    // ELIMINAR: Convertimos el ID a número para la consulta
    const { error } = await supabase
      .from('productos')
      .delete()
      .eq('id', id);

    if (error) {
      alert('Error al eliminar: ' + error.message);
    } else {
      console.log('Producto eliminado correctamente');
      await loadProducts();
    }
  }

  // Listeners de interfaz
  document.getElementById('open-create-modal')?.addEventListener('click', () => showModal(false));
  document.getElementById('close-modal')?.addEventListener('click', hideModal);
  document.getElementById('cancel-modal')?.addEventListener('click', hideModal);

  // Inicializar al cargar
  loadProducts();
</script>