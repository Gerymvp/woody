---
// src/components/Header.astro
---
<header class="relative w-full p-3 flex items-center justify-between shadow-2xl overflow-visible group">
  <div class="absolute inset-0 bg-[#231a12]"></div>

  <div
    class="absolute inset-0 opacity-50 mix-blend-soft-light pointer-events-none"
    style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 1000 1000%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22wood%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.003 0.15%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3CfeColorMatrix type=%22saturate%22 values=%220%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23wood)%22/%3E%3C/svg%3E'); background-size: cover; background-position: center;"
  ></div>

  <div
    class="absolute inset-0 opacity-[0.12] mix-blend-overlay pointer-events-none"
    style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.7%22 numOctaves=%221%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E');"
  ></div>

  <div class="absolute inset-0 bg-gradient-to-b from-white/10 via-transparent to-black/70"></div>
  <div class="absolute top-0 left-0 right-0 h-[1px] bg-white/10"></div>

  <div class="relative z-10 flex items-center justify-between w-full px-2 sm:px-4 gap-2">

    <!-- Logo: Reducido un poco en móviles para asegurar espacio -->
    <a href="/" class="relative bg-black/30 p-2 sm:p-2.5 rounded-xl text-white hover:bg-yellow-600 hover:text-black transition-all border border-white/10 shadow-lg backdrop-blur-sm">
      <span class="text-[#ffffff] font-black text-xl sm:text-2xl tracking-tighter uppercase">Swoo</span><span class="text-yellow-600 font-black text-xl sm:text-2xl tracking-tighter uppercase">dy</span>
    </a>

    <!-- Buscador: Oculto en móviles (`hidden`), visible desde tablets (`md:flex`) -->
    <div class="hidden md:flex flex-1 max-w-md mx-6">
      <div class="relative group w-full">
        <input
          type="text"
          placeholder="Buscar muebles de diseño..."
          class="w-full bg-black/60 border border-white/5 rounded-lg py-2 px-10 focus:outline-none focus:ring-1 focus:ring-yellow-600/50 text-white placeholder-gray-500 transition-all shadow-inner backdrop-blur-md"
        />
        <div class="absolute left-3 top-2.5 text-yellow-600/70 group-focus-within:text-yellow-500 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </div>
      </div>
    </div>

    <!-- Acciones de Usuario y Carrito -->
    <div class="flex items-center gap-2 sm:gap-4 flex-shrink-0">
      <a
        href="/carrito"
        class="relative bg-black/30 p-2 sm:p-2.5 rounded-xl text-white hover:bg-yellow-600 hover:text-black transition-all border border-white/10 shadow-lg backdrop-blur-sm"
        aria-label="Ver carrito"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="8" cy="21" r="1"/>
          <circle cx="19" cy="21" r="1"/>
          <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/>
        </svg>

        <span
          id="cart-count"
          class="absolute -right-2 -top-2 hidden min-w-5 rounded-full bg-yellow-500 px-1.5 py-0.5 text-center text-xs font-black text-black"
          aria-live="polite"
        >
          0
        </span>
      </a>

      <!-- Botón de Perfil adaptado -->
      <div class="relative">
        <!-- El padding horizontal cambia de `px-2` en móvil a `sm:px-4` -->
        <div id="profileBtn" class="flex items-center bg-black/30 border border-white/10 rounded-xl px-2 sm:px-4 py-2 gap-1 sm:gap-3 cursor-pointer hover:bg-black/40 hover:border-yellow-600/30 transition-all shadow-lg backdrop-blur-sm">

          <div class="bg-yellow-600 rounded-lg p-1 text-black">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
          </div>

          <!-- Texto "Mi Cuenta": oculto en móviles (`hidden`), visible en `sm:block` -->
          <span class="hidden sm:block font-medium text-gray-200 text-sm sm:text-base">Mi Cuenta</span>        
          <div class="text-white">
            <svg
              id="profileArrow"
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </div>

        </div>

        <div
          id="profileMenu"
          class="absolute right-0 mt-2 w-52 bg-[#231a12] border border-white/10 rounded-xl shadow-2xl backdrop-blur-md hidden z-50"
        >
          <a
            href="https://www.swoodypty.com/login"
            class="block px-4 py-3 text-gray-200 hover:bg-yellow-600 hover:text-black rounded-xl transition-colors"
          >
            Iniciar sesión
          </a>
          <a
            href="/register"
            class="block px-4 py-3 text-gray-200 hover:bg-yellow-600 hover:text-black rounded-b-xl border-t border-white/5 transition-colors"
          >
            Crear cuenta
          </a>
        </div>

      </div>
    </div>

  </div>
</header>

<script>
  // Tu script intacto se mantiene aquí abajo...
  import { CART_UPDATED_EVENT, getCartItemCount, isCartStorageEvent } from "../lib/cart.js";
  import { trackEvent } from "../lib/tracker";

  const arrow = document.getElementById("profileArrow");
  const menu = document.getElementById("profileMenu");

  arrow?.addEventListener("click", (e) => {
    e.stopPropagation();
    menu?.classList.toggle("hidden");
  });

  document.addEventListener("click", () => {
    menu?.classList.add("hidden");
  });

  const updateCartCount = () => {
    const counter = document.getElementById("cart-count");
    if (!counter) return;
    const count = getCartItemCount();
    counter.textContent = String(count);
    counter.classList.toggle("hidden", count === 0);
  };

  updateCartCount();
  window.addEventListener(CART_UPDATED_EVENT, updateCartCount);
  window.addEventListener("storage", (event) => {
    if (isCartStorageEvent(event)) updateCartCount();
  });

  document.querySelector('a[href="/carrito"]')?.addEventListener("click", () => trackEvent("click_carrito"));
  document.querySelector('a[href="https://www.swoodypty.com/login"]')?.addEventListener("click", () => trackEvent("click_login"));
  document.querySelector('a[href="/catalogo"]')?.addEventListener("click", () => trackEvent("click_catalogo", "sidebar_admin"));
</script>