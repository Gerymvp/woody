---
// src/components/Header.astro
---
<header class="relative w-full p-3 flex items-center justify-between shadow-2xl overflow-hidden group">
  <div class="absolute inset-0 bg-[#231a12]"></div>
  
  <div class="absolute inset-0 opacity-50 mix-blend-soft-light pointer-events-none" 
       style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 1000 1000%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22wood%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.003 0.15%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3CfeColorMatrix type=%22saturate%22 values=%220%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23wood)%22/%3E%3C/svg%3E'); 
              background-size: cover; background-position: center;">
  </div>

  <div class="absolute inset-0 opacity-[0.12] mix-blend-overlay pointer-events-none"
       style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.7%22 numOctaves=%221%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E');">
  </div>

  <div class="absolute inset-0 bg-gradient-to-b from-white/10 via-transparent to-black/70"></div>
  <div class="absolute top-0 left-0 right-0 h-[1px] bg-white/10"></div>

  <div class="relative z-10 flex items-center justify-between w-full px-4">
    
    <a href="/" class="bg-white px-4 py-1.5 rounded-sm shadow-[0_4px_0_rgb(0,0,0,0.6)] active:translate-y-[2px] active:shadow-[0_2px_0_rgb(0,0,0,0.6)] transition-all">
      <span class="text-black font-black text-2xl tracking-tighter uppercase">Swoo</span><span class="text-yellow-600 font-black text-2xl tracking-tighter uppercase">dy</span>
    </a>

    <div class="flex-1 max-w-md mx-6">
      <div class="relative group">
        <input 
          type="text" 
          placeholder="Buscar muebles de diseño..." 
          class="w-full bg-black/60 border border-white/5 rounded-lg py-2 px-10 focus:outline-none focus:ring-1 focus:ring-yellow-600/50 text-white placeholder-gray-500 transition-all shadow-inner backdrop-blur-md"
        />
        <div class="absolute left-3 top-2.5 text-yellow-600/70 group-focus-within:text-yellow-500 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        </div>
      </div>
    </div>

    <div class="flex items-center gap-4">
      <a href="/carrito" class="bg-black/30 p-2.5 rounded-xl text-white hover:bg-yellow-600 hover:text-black transition-all border border-white/10 shadow-lg backdrop-blur-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
      </a>

      <div class="relative">
        <div id="profileBtn" class="flex items-center bg-black/30 border border-white/10 rounded-xl px-4 py-2 gap-3 cursor-pointer hover:bg-black/40 transition-all shadow-lg backdrop-blur-sm">
          <div class="bg-yellow-600 rounded-lg p-1 text-black">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          </div>
          <span class="font-medium text-gray-200">Mi Cuenta</span>
          <svg class="text-gray-400" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </div>
      </div>
    </div>
  </div>
</header>