---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
---

<Layout title="Registrar Producto - Swoody">
  <Header />

  <div class="flex min-h-screen bg-white">
    
    <!-- Sidebar -->
    <aside class="w-64 p-6 border-r border-gray-200">
      <h2 class="text-center font-bold text-xl mb-6">Admin</h2>

      <nav class="space-y-4">
        <button class="w-full text-left py-3 px-4 rounded shadow-md border border-gray-100 bg-black text-white font-medium">
          Registrar Producto
        </button>

        <button class="w-full text-left py-3 px-4 rounded shadow-md border border-gray-100 hover:bg-gray-50 transition">
          Inventario
        </button>

        <button class="w-full text-left py-3 px-4 rounded shadow-md border border-gray-100 hover:bg-gray-50 transition">
          Pedidos
        </button>
      </nav>
    </aside>

    <!-- Contenido -->
    <main class="flex-1 p-8 overflow-y-auto">

      <!-- Encabezado -->
      <div class="mb-10">
        <h1 class="text-5xl font-bold mb-3">Nuevo Producto</h1>
        <p class="text-gray-500 text-lg">
          Agrega muebles al catálogo principal
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-8">

        <!-- Preview -->
        <div class="relative bg-gray-200 rounded-3xl aspect-[4/3] shadow-lg overflow-hidden">
          <div class="absolute inset-0 flex items-center justify-center text-gray-500 font-bold text-lg">
            Vista previa
          </div>

          <div class="absolute bottom-4 left-4 right-4 flex gap-2">
            <div class="bg-white/90 backdrop-blur px-4 py-2 rounded-lg text-sm font-bold shadow-sm">
              Precio
            </div>
            <div class="flex-1 bg-white/60 backdrop-blur px-6 py-2 rounded-full text-center font-bold text-gray-800 shadow-sm">
              Producto
            </div>
          </div>
        </div>

        <!-- Formulario -->
        <div class="bg-white rounded-3xl border border-gray-200 shadow-lg p-8">
          <form id="productoForm" class="space-y-6">

            <div>
              <label class="block mb-2 font-bold text-sm">
                Título
              </label>
              <input
                type="text"
                id="titulo"
                class="w-full border border-gray-200 rounded-xl px-4 py-4 focus:outline-none focus:ring-2 focus:ring-black"
                required
              />
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block mb-2 font-bold text-sm">
                  Precio
                </label>
                <input
                  type="number"
                  step="0.01"
                  id="precio"
                  class="w-full border border-gray-200 rounded-xl px-4 py-4"
                  required
                />
              </div>

              <div>
                <label class="block mb-2 font-bold text-sm">
                  Categoría
                </label>
                <select
                  id="categoria"
                  class="w-full border border-gray-200 rounded-xl px-4 py-4"
                >
                  <option>Sala</option>
                  <option>Comedor</option>
                  <option>Dormitorio</option>
                  <option>Empotrados</option>
                  <option>Oficina</option>
                </select>
              </div>
            </div>

            <div>
              <label class="block mb-2 font-bold text-sm">
                URL Imagen
              </label>
              <input
                type="text"
                id="imagen_url"
                class="w-full border border-gray-200 rounded-xl px-4 py-4"
              />
            </div>

            <div>
              <label class="block mb-2 font-bold text-sm">
                Mueblería ID
              </label>
              <input
                type="text"
                id="muebleria_id"
                class="w-full border border-gray-200 rounded-xl px-4 py-4"
              />
            </div>

            <button
              type="submit"
              class="w-full bg-black text-white py-4 rounded-xl font-bold hover:opacity-90 transition"
            >
              Guardar Producto
            </button>

            <p id="mensaje" class="text-center font-medium"></p>

          </form>
        </div>
      </div>
    </main>
  </div>
</Layout>

<script type="module">
  import { supabase } from '../../lib/supabase';

  const form = document.getElementById('productoForm');
  const mensaje = document.getElementById('mensaje');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const producto = {
      titulo: document.getElementById('titulo').value,
      precio: parseFloat(document.getElementById('precio').value),
      categoria: document.getElementById('categoria').value,
      imagen_url: document.getElementById('imagen_url').value,
      muebleria_id: document.getElementById('muebleria_id').value || null
    };

    const { error } = await supabase
      .from('productos')
      .insert([producto]);

    if (error) {
      mensaje.textContent = error.message;
      mensaje.className = "text-red-600 text-center font-medium";
    } else {
      mensaje.textContent = "Producto guardado correctamente";
      mensaje.className = "text-green-600 text-center font-medium";
      form.reset();
    }
  });
</script>