---
// src/pages/catalogo.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ProductCard from '../components/catalogo/ProductCard.astro';
import { supabase } from '../lib/supabase';

// Fetch de productos desde la tabla que creamos
const { data: productos, error } = await supabase
  .from('productos')
  .select('*');

---

<Layout title="Catálogo - Swoody">

  <div class="flex min-h-screen bg-white">
    <!-- Sidebar e interfaz... -->
    <main class="flex-1 p-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {error && (
          <p class="col-span-full rounded-2xl bg-red-50 p-6 text-center text-red-700">
            No pudimos cargar el catálogo. Intenta nuevamente más tarde.
          </p>
        )}
        {!error && productos?.length === 0 && (
          <p class="col-span-full rounded-2xl bg-gray-100 p-6 text-center text-gray-600">
            No hay productos disponibles por el momento.
          </p>
        )}
        {!error && productos?.map((prod) => (
          <ProductCard 
            id={prod.id}
            nombre={prod.nombre ?? prod.titulo}
            precio={prod.precio}
            imagen={prod.imagen_url}
            categoria={prod.categoria}
          />
        ))}
      </div>
    </main>
  </div>
</Layout>
