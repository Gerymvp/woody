---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const cartItems = [
  {
    title: "Sofá Moderno",
    price: 120,
    quantity: 2
  },
  {
    title: "Mesa de Centro",
    price: 80,
    quantity: 1
  }
];

const subtotal = cartItems.reduce(
  (acc, item) => acc + item.price * item.quantity,
  0
);

const tax = subtotal * 0.07;
const total = subtotal + tax;
---

<Layout title="Carrito - Swoody">
  <Header />

  <!-- Botón flotante carrito -->
  <a 
    href="/carrito"
    class="fixed bottom-8 right-8 bg-yellow-500 hover:bg-yellow-400 shadow-2xl hover:scale-110 transition-all duration-300 px-6 py-4 rounded-full font-bold z-50"
  >
    🛒 {cartItems.length} productos
  </a>

  <main class="max-w-7xl mx-auto p-8">
    
    <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-8 gap-4">

      <h1 class="text-4xl font-black">
        Mi Carrito
      </h1>

      <a
        href="/catalogo"
        class="bg-gray-100 hover:bg-yellow-500 hover:scale-105 transition-all duration-300 px-6 py-3 rounded-2xl font-bold text-center"
      >
        Seguir comprando
      </a>

    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      <!-- Productos -->
      <section class="lg:col-span-2 space-y-6">

        {cartItems.length === 0 ? (

          <div class="bg-white rounded-3xl shadow-lg p-16 text-center">

            <div class="text-7xl mb-6">
              🛒
            </div>

            <h2 class="text-3xl font-black mb-4">
              Tu carrito está vacío
            </h2>

            <p class="text-gray-500 mb-8">
              Explora nuestro catálogo y encuentra muebles increíbles para tu hogar.
            </p>

            <a
              href="/catalogo"
              class="inline-block bg-yellow-500 hover:bg-yellow-400 hover:scale-105 transition-all duration-300 px-8 py-4 rounded-2xl font-bold"
            >
              Explorar catálogo
            </a>

          </div>

        ) : (

          <div class="space-y-6">

            {cartItems.map((item) => (
              <div class="bg-white rounded-2xl shadow-lg hover:shadow-xl transition-all p-4 flex items-center gap-5">

                <!-- Imagen simulada -->
                <div class="w-32 h-28 rounded-2xl overflow-hidden flex-shrink-0">
                  <img 
                    src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?q=80&w=800&auto=format&fit=crop"
                    alt="Mueble"
                    class="w-full h-full object-cover"
                  />
                </div>

                <!-- Info -->
                <div class="flex-1 w-full">

                  <div class="flex justify-between items-start mb-4">
                    <div>
                      <h2 class="text-2xl font-bold">
                        {item.title}
                      </h2>

                      <p class="text-gray-500">
                        ${item.price}
                      </p>
                    </div>

                    <button class="text-red-500 font-bold hover:underline">
                      Eliminar
                    </button>
                  </div>

                  <!-- Cantidad -->
                  <div class="flex items-center gap-4">

                    <button class="bg-gray-200 px-4 py-2 rounded-xl font-bold hover:bg-gray-300">
                      -
                    </button>

                    <span class="font-bold text-lg">
                      {item.quantity}
                    </span>

                    <button class="bg-gray-200 px-4 py-2 rounded-xl font-bold hover:bg-gray-300">
                      +
                    </button>

                  </div>

                </div>

                <!-- Subtotal -->
                <div class="text-right">
                  <p class="text-gray-500 text-sm">
                    Subtotal
                  </p>

                  <p class="text-2xl font-black">
                    ${item.price * item.quantity}
                  </p>
                </div>

              </div>
            ))}

            </div>

          )}

      </section>

      <!-- Resumen -->
      <aside class="bg-white rounded-3xl shadow-lg p-8 h-fit sticky top-28">

        <h2 class="text-2xl font-bold mb-6">
          Resumen
        </h2>

        <div class="space-y-4 mb-6">

          <div class="flex justify-between">
            <span>Subtotal</span>
            <span>${subtotal.toFixed(2)}</span>
          </div>

          <div class="flex justify-between">
            <span>ITBMS</span>
            <span>${tax.toFixed(2)}</span>
          </div>

          <div class="border-t pt-4 flex justify-between text-xl font-black">
            <span>Total</span>
            <span>${total.toFixed(2)}</span>
          </div>

        </div>

        <button class="w-full bg-yellow-500 hover:bg-yellow-400 transition-all text-black font-bold py-4 rounded-2xl">
          Proceder al pago
        </button>

      </aside>

    </div>

    <!-- Recomendaciones -->
    <section class="mt-20">
      
      <div class="flex items-center justify-between mb-8">
        
        <div>
          <h2 class="text-3xl font-black">
            También podría interesarte
          </h2>

          <p class="text-gray-500 mt-1">
            Complementa tu compra con estos accesorios
          </p>
        </div>

      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">

        {[
          {
            title: "Lámpara Minimalista",
            price: 45,
            image: "https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?q=80&w=800&auto=format&fit=crop"
          },
          {
            title: "Mesa Auxiliar",
            price: 90,
            image: "https://images.unsplash.com/photo-1493663284031-b7e3aefcae8e?q=80&w=800&auto=format&fit=crop"
          },
          {
            title: "Cojines Decorativos",
            price: 25,
            image: "https://images.unsplash.com/photo-1484101403633-562f891dc89a?q=80&w=800&auto=format&fit=crop"
          },
          {
            title: "Alfombra Moderna",
            price: 70,
            image: "https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?q=80&w=800&auto=format&fit=crop"
          }
        ].map((item) => (

          <div class="bg-white rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 group">

            <!-- Imagen -->
            <div class="h-52 overflow-hidden">
              <img
                src={item.image}
                alt={item.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-all duration-300"
              />
            </div>

            <!-- Info -->
            <div class="p-5">

              <div class="flex justify-between items-start mb-4">

                <div>
                  <h3 class="font-bold text-lg">
                    {item.title}
                  </h3>

                  <p class="text-gray-500">
                    ${item.price}
                  </p>
                </div>

              </div>

              <button class="w-full bg-gray-100 hover:bg-yellow-500 hover:text-black hover:scale-105 transition-all duration-300 font-bold py-3 rounded-2xl">
                Añadir al carrito
              </button>

            </div>

          </div>

        ))}

      </div>

    </section>

  </main>
</Layout>