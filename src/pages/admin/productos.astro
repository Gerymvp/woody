---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
---

<Layout title="Registrar Producto - Swoody">
  <Header />

  <div class="min-h-screen bg-[#fafafa] px-6 py-12">
    <div class="max-w-5xl mx-auto">
      
        </p>
        <h1 class="text-5xl font-bold text-gray-900">
          Registrar Producto
        </h1>
        <p class="text-gray-500 mt-3 text-lg">
          Agrega nuevos muebles al catálogo de Swoody
        </p>
      </div>

      <!-- Card principal -->
      <div class="bg-white rounded-[32px] shadow-sm border border-gray-100 overflow-hidden">
        
        <div class="grid grid-cols-1 lg:grid-cols-2">
          
          <!-- Lado visual -->
          <div class="bg-gray-100 min-h-full p-10 flex flex-col justify-between">
            <div>
              <h2 class="text-3xl font-bold mb-4">
                Nuevo producto
              </h2>
              <p class="text-gray-600 leading-relaxed">
                Completa la información del producto para publicarlo automáticamente en el catálogo.
              </p>
            </div>

            <div class="mt-12 rounded-3xl bg-white p-8 shadow-sm border border-gray-200">
              <p class="text-sm text-gray-500 mb-2">Vista previa</p>
              <div class="aspect-[4/3] rounded-3xl bg-gray-300 flex items-center justify-center text-gray-500 font-medium">
                Imagen del producto
              </div>
            </div>
          </div>

          <!-- Formulario -->
          <div class="p-10">
            <form id="productoForm" class="space-y-7">

              <div>
                <label class="block text-sm font-semibold mb-3 text-gray-700">
                  Título
                </label>
                <input
                  type="text"
                  id="titulo"
                  class="w-full border border-gray-200 rounded-2xl px-5 py-4 focus:outline-none focus:ring-2 focus:ring-black transition"
                  required
                />
              </div>

              <div class="grid grid-cols-2 gap-5">
                <div>
                  <label class="block text-sm font-semibold mb-3 text-gray-700">
                    Precio
                  </label>
                  <input
                    type="number"
                    step="0.01"
                    id="precio"
                    class="w-full border border-gray-200 rounded-2xl px-5 py-4 focus:outline-none focus:ring-2 focus:ring-black"
                    required
                  />
                </div>

                <div>
                  <label class="block text-sm font-semibold mb-3 text-gray-700">
                    Categoría
                  </label>
                  <select
                    id="categoria"
                    class="w-full border border-gray-200 rounded-2xl px-5 py-4 focus:outline-none focus:ring-2 focus:ring-black"
                    required
                  >
                    <option value="Sala">Sala</option>
                    <option value="Comedor">Comedor</option>
                    <option value="Dormitorio">Dormitorio</option>
                    <option value="Empotrados">Empotrados</option>
                    <option value="Oficina">Oficina</option>
                  </select>
                </div>
              </div>

              <div>
                <label class="block text-sm font-semibold mb-3 text-gray-700">
                  URL Imagen
                </label>
                <input
                  type="text"
                  id="imagen_url"
                  class="w-full border border-gray-200 rounded-2xl px-5 py-4 focus:outline-none focus:ring-2 focus:ring-black"
                />
              </div>

              <div>
                <label class="block text-sm font-semibold mb-3 text-gray-700">
                  Mueblería ID
                </label>
                <input
                  type="text"
                  id="muebleria_id"
                  class="w-full border border-gray-200 rounded-2xl px-5 py-4 focus:outline-none focus:ring-2 focus:ring-black"
                />
              </div>

              <button
                type="submit"
                class="w-full bg-black text-white py-5 rounded-2xl font-bold hover:opacity-90 transition"
              >
                Guardar Producto
              </button>
            </form>

            <p id="mensaje" class="text-center mt-6 font-medium"></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script type="module">
  import { supabase } from '../../lib/supabase';

  const form = document.getElementById('productoForm');
  const mensaje = document.getElementById('mensaje');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const producto = {
      titulo: document.getElementById('titulo').value,
      precio: parseFloat(document.getElementById('precio').value),
      categoria: document.getElementById('categoria').value,
      imagen_url: document.getElementById('imagen_url').value,
      muebleria_id: document.getElementById('muebleria_id').value || null
    };

    const { error } = await supabase
      .from('productos')
      .insert([producto]);

    if (error) {
      mensaje.textContent = error.message;
      mensaje.className = "text-red-600 text-center mt-6 font-medium";
    } else {
      mensaje.textContent = "Producto guardado correctamente";
      mensaje.className = "text-green-600 text-center mt-6 font-medium";
      form.reset();
    }
  });
</script>