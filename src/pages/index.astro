---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Catalogo from './catalogo.astro';
---

<Layout title="Swoody - Muebles a domicilio">
	<Header />
	
	<Hero />

	<!-- Cambiamos las clases restrictivas por w-full para que el Header interno se expanda -->
	<main id="catalogo" class="w-full">
		<Catalogo />
	</main>
</Layout>

<script>
  import { trackEvent } from '../lib/tracker';
  trackEvent('visita_pagina', 'home');
</script>