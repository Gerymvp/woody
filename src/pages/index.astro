---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
---

<Layout title="Swoody - Muebles a domicilio">
	<Header />
	
	<!-- 2. Insertamos el Hero justo debajo del Header, fuera del main para que ocupe todo el ancho -->
	<Hero />

	<main class="max-w-7xl mx-auto p-8">
		<!-- Mueblerías Asociadas -->
		<h2 class="text-2xl font-bold mb-6">Mueblerías Asociadas</h2>
		<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
			{Array(4).fill(0).map((_, i) => (
				<div class="bg-gray-200 h-32 rounded-xl flex items-center justify-center font-bold text-gray-400">
					Logo Mueblería {i+1}
				</div>
			))}
		</div>
	</main>
</Layout>

<script>
  import { trackEvent } from '../lib/tracker';
  // Registrar visita a la página principal
  trackEvent('visita_pagina', 'home');
</script>